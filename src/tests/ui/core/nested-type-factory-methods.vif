const std = @import("std");
extern "c" fn printf(fmt: *const u8, ...) i32;

fn Pair(comptime T: type, comptime U: type) type {
    return struct {
        left: T,
        right: U,

        fn left_value(self: Self) T {
            return self.left;
        }
    };
}

fn Wrapper(comptime Inner: type) type {
    return struct {
        inner: Inner,
        bias: usize,

        fn checksum(self: Self) usize {
            return self.bias + @size_of(Inner);
        }
    };
}

fn main() void {
    const P = Pair(u8, usize);
    const W = Wrapper(P);
    const p: P = .{ .left = 9, .right = 33usize };
    const w: W = .{ .inner = p, .bias = 10usize };
    printf(std.slice.ptr("%u %u %u\n"), p.left_value(), w.inner.right, w.checksum());
}

//@ args: run
//@ stdout:
// 9 33 26
