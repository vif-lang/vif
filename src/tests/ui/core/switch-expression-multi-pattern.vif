const std = @import("std")
extern "c" fn printf(fmt: *const u8, ...) i32

fn classify(value: i32) i32 {
    var result: i32 = 0
    switch value {
        0 => { result = 10 }
        1, 2 => { result = 20 }
        else => { result = 30 }
    }
    return result
}

fn main() void {
    const a = classify(0)
    const b = classify(2)
    const c = classify(9)
    printf(std.slice.ptr(u8, "%d %d %d\n"), a, b, c)
}

//@ args: run
//@ stdout:
// 10 20 30
